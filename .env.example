# ==========================================
# AI RECRUITMENT AGENT - LOCAL CONFIGURATION
# ==========================================

# 1. LLM Provider Setup
# Currently supports OpenAI. (Anthropic support planned for v1.2)
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# The model used for the heavy evaluation pass
EVALUATOR_MODEL=gpt-4o-mini
# The model used for quick entity extraction (can be a smaller/cheaper model)
EXTRACTOR_MODEL=gpt-3.5-turbo

# 2. GitHub API Verification
# Required to avoid aggressive rate limits from GitHub.
# Generate one at: [https://github.com/settings/tokens](https://github.com/settings/tokens) (No scopes required for public data)
GITHUB_PAT=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 3. Application Settings
# Maximum number of resumes to process in a single batch (Prevents API abuse)
MAX_BATCH_SIZE=10
# Maximum file size in MB
MAX_FILE_SIZE_MB=5

# 4. Fallback / Performance
# Set to 'true' to enable Redis caching for GitHub API calls
ENABLE_CACHE=false
REDIS_URL=redis://localhost:6379/0
# Fallback to TF-IDF keyword matching if LLM fails
ENABLE_KEYWORD_FALLBACK=true
